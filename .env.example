# Bunny Database (libSQL) — apenas servidor; nunca exponha o token no cliente
# A URL do cluster tem de estar nesta variável (nome fixo exigido pelo projeto):
BUNNY_DATABASE_URL=libsql://your-database-id.lite.bunnydb.net
# Use um dos dois (o painel da Bunny pode mostrar só "Access token"):
BUNNY_DATABASE_TOKEN=your-access-token
# BUNNY_DATABASE_AUTH_TOKEN=your-access-token
# Logs [GhostChat:Bunny] no servidor (além de NODE_ENV=development):
# BUNNY_DB_LOG=1
# GET /api/health inclui bunnyRoomsRowCount (COUNT em `rooms`):
# GHOSTCHAT_HEALTH_STATS=1

# URL pública do Edge Script (REST + WebSocket) após deploy na Bunny
NEXT_PUBLIC_EDGE_API_URL=https://your-pullzone.b-cdn.net

# URL pública do app (para montar links no painel em produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bunny Storage — upload de imagens no chat (HTTP API + Pull Zone)
# Password = "FTP & API Access" da storage zone (header AccessKey), NÃO a API key global da conta.
# BUNNY_STORAGE_API_HOST = endpoint da região (podes usar só o hostname; o app acrescenta https://), ex.:
#   storage.bunnycdn.com  ou  https://ny.storage.bunnycdn.com
# NEXT_PUBLIC_BUNNY_CDN_URL = Pull Zone (hostname ou URL completa; sem barra final), ex. xxx.b-cdn.net
# Se usar domínio customizado no Pull Zone, acrescente também em next.config.ts → images.remotePatterns.
BUNNY_STORAGE_ZONE_NAME=your-storage-zone-name
BUNNY_STORAGE_PASSWORD=your-storage-zone-ftp-api-password
# BUNNY_STORAGE_API_HOST=https://storage.bunnycdn.com
NEXT_PUBLIC_BUNNY_CDN_URL=https://your-pullzone.b-cdn.net

# Dev atrás de túnel/CDN: hosts permitidos para HMR (WebSocket), separados por vírgula
# NEXT_DEV_ALLOWED_ORIGINS=ghostchat.fastlyf.com
