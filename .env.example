# Bunny Database (libSQL) — apenas servidor; nunca exponha o token no cliente
# A URL do cluster tem de estar nesta variável (nome fixo exigido pelo projeto):
BUNNY_DATABASE_URL=libsql://your-database-id.lite.bunnydb.net
# Use um dos dois (o painel da Bunny pode mostrar só "Access token"):
BUNNY_DATABASE_TOKEN=your-access-token
# BUNNY_DATABASE_AUTH_TOKEN=your-access-token
# Logs [GhostChat:Bunny] no servidor (além de NODE_ENV=development):
# BUNNY_DB_LOG=1
# GET /api/health inclui bunnyRoomsRowCount (COUNT em `rooms`):
# GHOSTCHAT_HEALTH_STATS=1

# URL pública do Edge Script (REST + WebSocket) após deploy na Bunny
NEXT_PUBLIC_EDGE_API_URL=https://your-pullzone.b-cdn.net

# URL pública do app (para montar links no painel em produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bunny Storage — upload de imagens no chat (HTTP API + Pull Zone)
# Password = "FTP & API Access" da storage zone (header AccessKey), NÃO a API key global da conta.
# BUNNY_STORAGE_API_HOST = endpoint da região (podes usar só o hostname; o app acrescenta https://), ex.:
#   storage.bunnycdn.com  ou  https://ny.storage.bunnycdn.com
# NEXT_PUBLIC_BUNNY_CDN_URL = Pull Zone (hostname ou URL completa; sem barra final), ex. xxx.b-cdn.net
# Se usar domínio customizado no Pull Zone, acrescente também em next.config.ts → images.remotePatterns.
BUNNY_STORAGE_ZONE_NAME=your-storage-zone-name
BUNNY_STORAGE_PASSWORD=your-storage-zone-ftp-api-password
# BUNNY_STORAGE_API_HOST=https://storage.bunnycdn.com
NEXT_PUBLIC_BUNNY_CDN_URL=https://your-pullzone.b-cdn.net

# Dev atrás de túnel/CDN: hosts permitidos para HMR (WebSocket), separados por vírgula
# NEXT_DEV_ALLOWED_ORIGINS=ghosth.chat

# —— Pagamento PIX (Woovi) ——
# URL da API (padrão https://api.woovi.com se omitido)
# WOOVI_API_URL=https://api.woovi.com
# Header Authorization enviado à Woovi (ex.: "Authorization: <appId>" conforme doc Woovi)
WOOVI_AUTH=
# Segredo HS256 para JWT de sessão após pagamento (painel → POST /api/rooms com Bearer)
GHOSTCHAT_SESSION_SECRET=
# Apenas desenvolvimento: criar salas sem pagamento (não usar em produção)
# GHOSTCHAT_BYPASS_PAYMENT=1
# Modo interno (painel): segredo forte no servidor; cookie HttpOnly após ativar (7 dias).
# GHOSTCHAT_ADMIN_SECRET=defina-um-segredo-longo-e-aleatorio
# Token público para desbloquear o bloco "Acesso interno" — NÃO use o mesmo do GHOSTCHAT_ADMIN_SECRET.
# A validação é feita no servidor (path e query), por isso o valor no painel do host aplica-se sem novo build.
# Produção (recomendado): https://seu-dominio/panel/i/O-MESMO-VALOR-ABAIXO
# Legado (query): /panel?ghostchat_admin=... (pode falhar atrás de alguns CDNs)
# NEXT_PUBLIC_GHOSTCHAT_ADMIN_UNLOCK_TOKEN=escolha-um-token-para-o-path
# NEXT_PUBLIC_GHOSTCHAT_ADMIN_QUERY_TOKEN=  # só se precisar do fallback ?ghostchat_admin=
#
# Compra PIX customizada (quantidade de links + valor) — só acessível em /panel/o/<este-token>
# GHOSTCHAT_CUSTOM_PURCHASE_PATH_TOKEN=escolha-um-token-secreto-para-o-path
#
# Webhook Woovi (painel Woovi → Webhooks): URL exata do teu site + caminho abaixo (HTTPS).
# Exemplo: https://ghosth.chat/api/payment/webhook
# App iOS nativo — variável obrigatória no servidor para o header / Bearer bater certo após redeploy na Vercel.
# Alias aceites em código: GHOSTCHAT_IOS_SECRET ou IOS_NATIVE_API_SECRET (para typos em painéis antigos).
# GHOSTCHAT_IOS_API_SECRET=gerar_um_segredo_longo_unico

# Caminho fixo: /api/payment/webhook
# 1 link grátis para testes (mostra botão no painel; desligado se omitido)
# GHOSTCHAT_ENABLE_FREE_TEST_LINK=1
# Dados sintéticos na cobrança Woovi (um email único por PIX; não pedimos dados ao utilizador)
# GHOSTCHAT_PIX_EMAIL_DOMAIN=ghostchat.local
# GHOSTCHAT_PIX_CUSTOMER_NAME=Cliente Ghost Chat
# GHOSTCHAT_PIX_CUSTOMER_PHONE=5511999999999
